<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <div class="page-noise"></div>
    <%- include('../partials/header') %>

    <main>
      <section class="hero shell">
        <div
          class="banner banner-success <%= waitlistSuccessProduct ? '' : 'is-hidden' %>"
          data-access-success-banner
        >
          <% if (waitlistSuccessProduct) { %>
            Early access request saved for <strong><%= waitlistSuccessProduct.name %></strong>.
          <% } %>
        </div>

        <div class="hero-grid">
          <div>
            <p class="eyebrow">OmniToolset</p>
            <h1><%= homepageHeadline %></h1>
            <p class="hero-copy">
              OmniToolset is a focused suite of AI tools for local businesses. SMS AI Assistant is live today, and four more products are already staged with honest beta and coming-soon positioning.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="<%= liveProduct.pagePath %>">Get Started</a>
              <a class="button button-secondary" href="<%= liveProduct.secondaryAction.href %>">Request Demo</a>
            </div>

            <div class="hero-fact-row">
              <% for (const fact of platformFacts) { %>
                <div class="fact-chip">
                  <strong><%= fact.value %></strong>
                  <span><%= fact.label %></span>
                </div>
              <% } %>
            </div>
          </div>

          <aside>
            <p class="panel-label">Live today</p>
            <%- include('../partials/product-card', { product: liveProduct, featured: true }) %>
          </aside>
        </div>
      </section>

      <section class="shell section-space" id="products">
        <div class="section-heading">
          <p class="eyebrow">Platform products</p>
          <h2>One suite, five focused tools</h2>
          <p class="section-copy">
            Each product has its own page, status label, and clear next step. SMS AI Assistant is the live starting point for the suite.
          </p>
        </div>

        <div class="product-grid">
          <% for (const product of products) { %>
            <%- include('../partials/product-card', { product, featured: false }) %>
          <% } %>
        </div>
      </section>

      <section class="shell section-space">
        <div class="two-column-panel">
          <div class="content-card">
            <p class="panel-label">Platform rollout</p>
            <h2>What is live today and what is staged next</h2>
            <ul class="feature-list">
              <li>SMS AI Assistant is the first real OmniToolset product, not a placeholder.</li>
              <li>Review Booster and Follow-up Automation are visible beta modules collecting early access interest.</li>
              <li>Lead Capture AI and Inbox / Simple CRM are coming soon and intentionally linked to early access instead of fake workflows.</li>
            </ul>
          </div>

          <form class="waitlist-form content-card" action="<%= accessRequestAction %>" method="post">
            <p class="panel-label">Early access</p>
            <h2>Tell us what to ship next</h2>
            <p class="section-copy">
              Pick a staged module and we will let you know when beta or waitlist access opens. No login and no fake demo flow.
            </p>

            <input type="hidden" name="returnTo" value="<%= homeAccessReturnTo %>" />

            <label>
              Product
              <select name="productSlug" required>
                <% for (const product of products.filter((item) => item.waitlistEnabled)) { %>
                  <option value="<%= product.slug %>"><%= product.name %> (<%= product.status %>)</option>
                <% } %>
              </select>
            </label>

            <label>
              Name
              <input type="text" name="name" required maxlength="120" autocomplete="name" placeholder="Alex Morgan" />
            </label>

            <label>
              Email
              <input type="email" name="email" required maxlength="160" autocomplete="email" placeholder="alex@company.com" />
            </label>

            <label>
              Company Name
              <input type="text" name="company" required maxlength="160" autocomplete="organization" placeholder="Northstar Health" />
            </label>

            <label>
              Note
              <textarea name="note" rows="3" maxlength="1000" placeholder="Which workflow should OmniToolset ship next for your team?"></textarea>
            </label>

            <p class="form-help">We will only use this to follow up about early access for the module you selected.</p>

            <button class="button button-primary" type="submit">Request Early Access</button>
          </form>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
