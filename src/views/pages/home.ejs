<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <div class="page-noise"></div>
    <%- include('../partials/header') %>

    <main>
      <section class="hero shell">
        <% if (waitlistSuccessProduct) { %>
          <div class="banner banner-success">
            Early access request saved for <strong><%= waitlistSuccessProduct.name %></strong>.
          </div>
        <% } %>

        <div class="hero-grid">
          <div>
            <p class="eyebrow">AI-powered business tools</p>
            <h1><%= homepageHeadline %></h1>
            <p class="hero-copy">
              OmniToolset is structured as a platform, not a one-off script: one live product today, four staged modules ready for future rollout under the same codebase.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="<%= liveProduct.pagePath %>">Open SMS AI Assistant</a>
              <a class="button button-secondary" href="#products">See all products</a>
            </div>
          </div>

          <aside class="hero-panel">
            <p class="panel-label">Current Release</p>
            <div class="hero-metric-row">
              <div>
                <strong>5</strong>
                <span>product modules</span>
              </div>
              <div>
                <strong>1</strong>
                <span>live MVP</span>
              </div>
              <div>
                <strong>4</strong>
                <span>staged products</span>
              </div>
            </div>
            <p class="panel-copy">
              SMS AI Assistant is the only fully implemented module in this build. The remaining modules are scaffolded with their own pages, APIs, status labels, and waitlist capture.
            </p>
          </aside>
        </div>
      </section>

      <section class="shell section-space" id="products">
        <div class="section-heading">
          <p class="eyebrow">Product lineup</p>
          <h2>Five tools, one platform shell</h2>
        </div>

        <div class="product-grid">
          <% for (const product of products) { %>
            <article class="product-card">
              <div class="card-topline">
                <span class="status-badge status-<%= product.status.toLowerCase().replace(/\s+/g, '-') %>"><%= product.status %></span>
                <span class="module-tag"><%= product.moduleId %></span>
              </div>
              <h3><%= product.name %></h3>
              <p><%= product.summary %></p>
              <ul class="feature-list">
                <% for (const item of product.highlights) { %>
                  <li><%= item %></li>
                <% } %>
              </ul>
              <div class="card-actions">
                <a class="button button-secondary" href="<%= product.pagePath %>">View Product</a>
                <% if (product.waitlistEnabled) { %>
                  <span class="card-meta">Early access available</span>
                <% } else { %>
                  <span class="card-meta">Live module</span>
                <% } %>
              </div>
            </article>
          <% } %>
        </div>
      </section>

      <section class="shell section-space">
        <div class="two-column-panel">
          <div>
            <p class="eyebrow">Early access</p>
            <h2>Join the list for staged products</h2>
            <p class="panel-copy">
              Review Booster, Follow-up Automation, Lead Capture AI, and Inbox / Simple CRM are intentionally scaffolded. Use the form to register interest without pretending those features already exist.
            </p>
          </div>

          <form class="waitlist-form" action="/waitlist" method="post">
            <input type="hidden" name="returnTo" value="/" />

            <label>
              Product
              <select name="productSlug" required>
                <% for (const product of products.filter((item) => item.waitlistEnabled)) { %>
                  <option value="<%= product.slug %>"><%= product.name %> (<%= product.status %>)</option>
                <% } %>
              </select>
            </label>

            <label>
              Name
              <input type="text" name="name" required placeholder="Alex Morgan" />
            </label>

            <label>
              Email
              <input type="email" name="email" required placeholder="alex@company.com" />
            </label>

            <label>
              Notes
              <textarea name="notes" rows="3" placeholder="Which workflow should OmniToolset ship next?"></textarea>
            </label>

            <button class="button button-primary" type="submit">Join Early Access</button>
          </form>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
