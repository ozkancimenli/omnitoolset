<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <div class="page-noise"></div>
    <%- include('../partials/header') %>

    <main class="shell section-space">
      <% if (waitlistSuccessProduct && waitlistSuccessProduct.slug === product.slug) { %>
        <div class="banner banner-success">
          Early access request saved for <strong><%= product.name %></strong>.
        </div>
      <% } %>

      <section class="product-hero">
        <div>
          <p class="eyebrow">OmniToolset product module</p>
          <div class="hero-title-row">
            <h1><%= product.name %></h1>
            <span class="status-badge status-<%= product.status.toLowerCase().replace(/\s+/g, '-') %>"><%= product.status %></span>
          </div>
          <p class="hero-copy"><%= product.headline %></p>
        </div>
        <aside class="hero-panel">
          <p class="panel-label">Status</p>
          <p class="panel-copy">
            <% if (product.status === 'Live') { %>
              This is the only fully implemented module in the current platform release.
            <% } else if (product.status === 'Beta') { %>
              This module is scaffolded honestly as a beta-stage product. Core workflows are not implemented yet.
            <% } else { %>
              This module is intentionally staged as coming soon. The architecture and waitlist path are live, but product workflows are not.
            <% } %>
          </p>
        </aside>
      </section>

      <section class="content-grid">
        <article class="content-card">
          <h2>What exists right now</h2>
          <p><%= product.summary %></p>
          <ul class="feature-list">
            <% for (const item of product.highlights) { %>
              <li><%= item %></li>
            <% } %>
          </ul>
        </article>

        <article class="content-card">
          <h2>Planned next</h2>
          <ul class="feature-list">
            <% for (const item of product.plannedCapabilities) { %>
              <li><%= item %></li>
            <% } %>
          </ul>
        </article>
      </section>

      <% if (product.moduleId === 'sms_assistant') { %>
        <section class="section-space content-grid">
          <article class="content-card">
            <h2>What the live MVP handles</h2>
            <ul class="feature-list">
              <li><%= smsPageData.publicSummary.bookingFlow %></li>
              <li><%= smsPageData.publicSummary.missedCallFlow %></li>
              <li>The assistant keeps replies short, friendly, and booking-oriented.</li>
            </ul>
          </article>

          <article class="content-card">
            <h2>How rollout works</h2>
            <ul class="feature-list">
              <li>SMS AI Assistant is the only live product in the current OmniToolset release.</li>
              <li>Operational setup is handled during onboarding, not shown publicly to visitors.</li>
              <li><%= smsPageData.publicSummary.onboarding %></li>
            </ul>
          </article>
        </section>
      <% } else { %>
        <section class="section-space two-column-panel">
          <div>
            <p class="eyebrow">Waitlist</p>
            <h2>Request access without pretending this is shipped</h2>
            <p class="panel-copy">
              This module has a page, a status endpoint, and shared architecture hooks, but the workflow itself is not implemented yet.
            </p>
          </div>

          <%- include('../partials/waitlist-form', { product, returnTo: product.pagePath }) %>
        </section>
      <% } %>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
