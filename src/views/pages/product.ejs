<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body>
    <div class="page-noise"></div>
    <%- include('../partials/header') %>

    <main class="shell section-space">
      <% if (waitlistSuccessProduct && waitlistSuccessProduct.slug === product.slug) { %>
        <div class="banner banner-success">
          Early access request saved for <strong><%= product.name %></strong>.
        </div>
      <% } %>

      <section class="product-hero">
        <div>
          <p class="eyebrow">OmniToolset product module</p>
          <div class="hero-title-row">
            <h1><%= product.name %></h1>
            <span class="status-badge status-<%= product.status.toLowerCase().replace(/\s+/g, '-') %>"><%= product.status %></span>
          </div>
          <p class="hero-copy"><%= product.headline %></p>
        </div>
        <aside class="hero-panel">
          <p class="panel-label">Status</p>
          <p class="panel-copy">
            <% if (product.status === 'Live') { %>
              This is the only fully implemented module in the current platform release.
            <% } else if (product.status === 'Beta') { %>
              This module is scaffolded honestly as a beta-stage product. Core workflows are not implemented yet.
            <% } else { %>
              This module is intentionally staged as coming soon. The architecture and waitlist path are live, but product workflows are not.
            <% } %>
          </p>
        </aside>
      </section>

      <section class="content-grid">
        <article class="content-card">
          <h2>What exists right now</h2>
          <p><%= product.summary %></p>
          <ul class="feature-list">
            <% for (const item of product.highlights) { %>
              <li><%= item %></li>
            <% } %>
          </ul>
        </article>

        <article class="content-card">
          <h2>Planned next</h2>
          <ul class="feature-list">
            <% for (const item of product.plannedCapabilities) { %>
              <li><%= item %></li>
            <% } %>
          </ul>
        </article>
      </section>

      <% if (product.slug === 'sms-ai-assistant') { %>
        <section class="section-space content-grid">
          <article class="content-card">
            <h2>Live module metrics</h2>
            <div class="stat-grid">
              <div class="stat-card">
                <strong><%= smsPageData.stats.openConversations %></strong>
                <span>Open conversations</span>
              </div>
              <div class="stat-card">
                <strong><%= smsPageData.stats.totalMessages %></strong>
                <span>Total stored messages</span>
              </div>
              <div class="stat-card">
                <strong><%= smsPageData.stats.confirmedBookings %></strong>
                <span>Confirmed bookings</span>
              </div>
            </div>
          </article>

          <article class="content-card">
            <h2>Booking behavior</h2>
            <ul class="feature-list">
              <li>Incoming SMS is stored before the assistant replies.</li>
              <li>The assistant suggests one or two nearby time slots.</li>
              <li>When the customer selects a slot, the booking is marked confirmed.</li>
              <li>Missed calls trigger an automatic SMS follow-up with booking options.</li>
            </ul>
          </article>
        </section>

        <section class="section-space content-grid">
          <article class="content-card">
            <h2>Webhook endpoints</h2>
            <div class="code-block">
              <code>POST <%= smsPageData.webhooks.sms %></code>
            </div>
            <div class="code-block">
              <code>POST <%= smsPageData.webhooks.voiceIncoming %></code>
            </div>
            <div class="code-block">
              <code>POST <%= smsPageData.webhooks.voiceDialResult %></code>
            </div>
            <p class="small-copy">
              Default business: <strong><%= smsPageData.business.name %></strong> on <strong><%= smsPageData.business.phone || 'set DEFAULT_BUSINESS_PHONE' %></strong> in <strong><%= smsPageData.business.timezone %></strong>.
            </p>
          </article>

          <article class="content-card">
            <h2>Local test commands</h2>
            <div class="code-block">
              <pre><code>curl -X POST <%= smsPageData.webhooks.sms %> \
  -d 'From=+15550000001' \
  -d 'To=<%= smsPageData.business.phone || '+15551234567' %>' \
  -d 'Body=Hi, can I book for tomorrow afternoon?' \
  -d 'MessageSid=SM-demo-001'</code></pre>
            </div>
            <div class="code-block">
              <pre><code>curl -X POST <%= smsPageData.webhooks.voiceDialResult %> \
  -d 'From=+15550000001' \
  -d 'To=<%= smsPageData.business.phone || '+15551234567' %>' \
  -d 'CallSid=CA-demo-001' \
  -d 'DialCallStatus=no-answer'</code></pre>
            </div>
          </article>
        </section>
      <% } else { %>
        <section class="section-space two-column-panel">
          <div>
            <p class="eyebrow">Waitlist</p>
            <h2>Request access without pretending this is shipped</h2>
            <p class="panel-copy">
              This module has a page, a status endpoint, and shared architecture hooks, but the workflow itself is not implemented yet.
            </p>
          </div>

          <%- include('../partials/waitlist-form', { product, returnTo: product.path }) %>
        </section>
      <% } %>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
