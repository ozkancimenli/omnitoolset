{
  "name": "@omnitoolset/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "test": "node --test test/*.test.js",
    "check": "find src test -name '*.js' -print0 2>/dev/null | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@omnitoolset/shared": "file:../../packages/shared",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "luxon": "^3.6.1",
    "openai": "^6.8.1",
    "pg": "^8.16.3",
    "stripe": "^18.4.0",
    "twilio": "^5.10.3"
  },
  "devDependencies": {
    "supertest": "^7.1.4"
  }
}
